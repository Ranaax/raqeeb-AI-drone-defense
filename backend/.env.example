# PostgreSQL
DB_HOST=localhost
DB_PORT=5433
DB_NAME=history
DB_USER=postgres
DB_PASSWORD=change_me

# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Admin token for write/approve/reject endpoints
ADMIN_TOKEN=replace_with_a_long_random_string

# YOLO + tracker
YOLO_WEIGHTS=../models/best.pt
YOLO_IMGSZ=640
YOLO_CONF=0.50
YOLO_IOU=0.45
TRACKER_CFG=../scripts/bytetrack_drone.yaml

# Pipeline
INFERENCE_FRAME_SKIP=2
INFERENCE_QUEUE_MAX=2
THREAT_CONF_THRESHOLD=0.6
THREAT_ETA_SECONDS=60

# --- LLM backend ---
# "local"  -> in-process Qwen2.5-3B + drone_qa_qwen LoRA via transformers + peft
# "ollama" -> hit a local Ollama server (qwen2.5:7b by default)
LLM_BACKEND=local

# Ollama (used when LLM_BACKEND=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Local LLM (used when LLM_BACKEND=local)
# Base model is auto-downloaded from HuggingFace on first run.
LLM_BASE_MODEL=Qwen/Qwen2.5-3B
LLM_LORA_PATH=../models/llm/drone_qa_qwen_lora_saved
LLM_MAX_NEW_TOKENS=512
LLM_TEMPERATURE=0.3
LLM_TOP_P=0.9

# Demo fallback
FALLBACK_VIDEO=../data/raw/shahed.mp4
