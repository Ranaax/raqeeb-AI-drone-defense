models/llm/

# Cowork / agent-mode write-test artifacts. The literal "C:" folder name
# uses a Unicode lookalike (U+F03A) that gets created when a tool hands
# a Windows-style path to a Linux-side mkdir.
.cowork-write-test
**/.cowork-write-test
